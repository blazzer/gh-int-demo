name: Deploy

# Fly deploy is opt-in: set repository secret FLY_API_TOKEN to enable.
# Without it, the deploy job completes immediately after CI.

on:
  push:
    branches: [main]

concurrency:
  group: deploy-${{ github.ref }}
  cancel-in-progress: true

jobs:
  ci:
    uses: ./.github/workflows/ci.yml

  deploy:
    needs: ci
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Check Fly deploy enabled
        id: fly
        env:
          FLY_API_TOKEN: ${{ secrets.FLY_API_TOKEN }}
        run: |
          if [ -z "$FLY_API_TOKEN" ]; then
            echo "FLY_API_TOKEN not set — skipping Fly.io deploy"
            echo "enabled=false" >> "$GITHUB_OUTPUT"
          else
            echo "enabled=true" >> "$GITHUB_OUTPUT"
          fi

      - uses: superfly/flyctl-actions/setup-flyctl@master
        if: steps.fly.outputs.enabled == 'true'

      - name: Deploy to Fly.io
        if: steps.fly.outputs.enabled == 'true'
        env:
          FLY_API_TOKEN: ${{ secrets.FLY_API_TOKEN }}
        run: |
          flyctl deploy --remote-only \
            --build-arg VERSION=${{ github.ref_name }} \
            --build-arg COMMIT=${{ github.sha }}

      - name: Smoke test live health check
        if: steps.fly.outputs.enabled == 'true'
        env:
          FLY_API_TOKEN: ${{ secrets.FLY_API_TOKEN }}
        run: |
          HOST=$(flyctl status --json | jq -r '.Hostname')
          URL="https://${HOST}/healthz"
          echo "Checking ${URL}"
          BODY=$(curl -sf "$URL")
          echo "$BODY"
          echo "$BODY" | jq -e '.status == "ok" and .commit == "${{ github.sha }}"'
